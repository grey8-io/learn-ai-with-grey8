# =============================================================================
# Environment Variables for Learn AI With Grey8
# =============================================================================
# Copy this file to .env:  cp .env.example .env
# The setup script (bash scripts/setup.sh) does this automatically and
# updates TUTOR_OLLAMA_MODEL to match your installed model.
# =============================================================================

# --- Tutor Engine (FastAPI) ---
# All tutor settings use the TUTOR_ prefix (read by pydantic-settings).
TUTOR_OLLAMA_HOST=http://localhost:11434
TUTOR_OLLAMA_MODEL=llama3.2:3b
TUTOR_HOST=0.0.0.0
TUTOR_PORT=8000
TUTOR_CORS_ORIGINS=["http://localhost:3000"]

# --- Ollama Inference Tuning (auto-configured by setup-ollama.sh) ---
# Override these only if you want to manually control Ollama performance.
# 0 = use hardware profile or Ollama default. -1 for num_gpu = auto-detect.
# TUTOR_OLLAMA_NUM_CTX=0
# TUTOR_OLLAMA_NUM_BATCH=0
# TUTOR_OLLAMA_NUM_GPU=-1

# --- Deployment mode + inference backend (hosted course) ---
# Local-first default: Ollama, no metering. Leave as-is for normal local use.
# WARNING: "hosted" turns on the auth gate — the AI tutor, grading, and hints
# then REQUIRE a signed-in Supabase account and will return 401 without one.
# Only set this if you are rehearsing the hosted course (see "Rehearsing Hosted
# Mode Locally" in docs/getting-started.md). For normal local use, keep "local".
# TUTOR_DEPLOYMENT_MODE=local            # local | hosted (hosted enables the quota seam)
# TUTOR_INFERENCE_BACKEND=ollama         # ollama | openai_compat
# For openai_compat (DeepInfra/Together/Groq — or Ollama's own /v1 for a free test):
# TUTOR_INFERENCE_BASE_URL=https://api.deepinfra.com/v1/openai
# TUTOR_INFERENCE_API_KEY=               # provider key (NEVER commit a real key)
# TUTOR_INFERENCE_MODEL=meta-llama/Llama-3.2-3B-Instruct
# TUTOR_INFERENCE_CONTEXT_LENGTH=8192
# TUTOR_INFERENCE_MAX_TOKENS=512

# --- Hosted free-tier quotas + spend circuit-breaker (hosted mode only) ---
# Per-account daily caps; the LLM rubric is the metered grading perk (tests-only
# grading stays free). global_daily_metered_cap is the kill-switch across all
# accounts (0 = disabled).
# TUTOR_FREE_TUTOR_MSGS_PER_DAY=20
# TUTOR_FREE_HINTS_PER_DAY=60
# TUTOR_FREE_RUBRIC_GRADINGS_PER_DAY=15
# TUTOR_GLOBAL_DAILY_METERED_CAP=0

# --- Supabase ---
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# --- Platform (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_TUTOR_URL=http://localhost:8000
